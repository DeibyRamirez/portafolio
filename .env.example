NEXT_PUBLIC_API_URL=http://localhost:3000/api
MONGODB_URI=
PORTFOLIO_API_KEY=

# Firebase Admin (subida de imagenes desde la API)
#
# Opcion A — archivo local (mas facil en desarrollo):
# 1. Firebase Console → Project Settings → Service Accounts → Generate new private key
# 2. Guarda el JSON como firebase-service-account.json en la raiz del proyecto
# 3. Descomenta la linea de abajo:
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
#
# Opcion B — JSON en variable (Vercel / produccion):
FIREBASE_SERVICE_ACCOUNT_JSON=
#
# Opcion C — variables separadas:
# FIREBASE_PROJECT_ID=
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY=

PORT=3000
NODE_ENV=development
